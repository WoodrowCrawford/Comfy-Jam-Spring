  m_Script: {fileID: 11500000, guid: 3667a4296b0115b40ad167e804a58408, type: 3}
  m_Name: StartDayDialogue
  m_EditorClassIdentifier: Assembly-CSharp::DialogueObjectBehavior
  _dialogue:
  - text: Ah, another fine spring morning. Up you get!
    speakerSpriteA: {fileID: 762295401419478983, guid: 8d1bb7c4be1714eb1aebaccc276f9104, type: 3}
    speakerSpriteB: {fileID: 6534564831102106899, guid: 524fa7d7012c34fd190c9eeb15971b1d, type: 3}
  - text: Zzz... 5 more minutes...
    speakerSpriteA: {fileID: -6580467855138769401, guid: f7224a65a95a6407ba8ad346ad2e44fc, type: 3}
    speakerSpriteB: {fileID: 8331951880562680293, guid: ba7b068bd9676499590fcd9755529306, type: 3}
  - text: Here's today's list. Take your time during the search; there's nothing
      like a walk in the great forest of Zirrala. I'll see you at supper.
    speakerSpriteA: {fileID: -6580467855138769401, guid: f7224a65a95a6407ba8ad346ad2e44fc, type: 3}
    speakerSpriteB: {fileID: 8331951880562680293, guid: ba7b068bd9676499590fcd9755529306, type: 3}
  _responses: []
